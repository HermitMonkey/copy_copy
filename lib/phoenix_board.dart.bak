import 'package:flutter/material.dart';
import 'package:flutter/services.dart';

class PhoenixBoard extends StatelessWidget {
  final List<String> history;
  final VoidCallback onHide;

  const PhoenixBoard({super.key, required this.history, required this.onHide});

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      backgroundColor: Colors.white,
      body: LayoutBuilder(
        builder: (context, constraints) {
          return Row(
            crossAxisAlignment: CrossAxisAlignment.start,
            children: [
              // LEFT SIDE: AI Insight Area
              Expanded(
                flex: 2,
                child: SingleChildScrollView(
                  padding: const EdgeInsets.all(24),
                  child: Column(
                    crossAxisAlignment: CrossAxisAlignment.start,
                    children: [
                      _buildToolBar(context),
                      const SizedBox(height: 32),
                      const Text(
                        "AI INSIGHTS",
                        style: TextStyle(
                          letterSpacing: 1.2,
                          fontWeight: FontWeight.bold,
                          color: Colors.grey,
                          fontSize: 11,
                        ),
                      ),
                      const SizedBox(height: 16),
                      _buildInsightGrid(),
                    ],
                  ),
                ),
              ),

              const VerticalDivider(
                width: 1,
                thickness: 1,
                color: Color(0xFFEEEEEE),
              ),

              // RIGHT SIDE: The Numbered Paste Vault
              Container(
                width: constraints.maxWidth > 600 ? 280 : 180,
                color: const Color(0xFFF9F9FB),
                child: Column(
                  crossAxisAlignment: CrossAxisAlignment.start,
                  children: [
                    const Padding(
                      padding: EdgeInsets.fromLTRB(16, 24, 16, 8),
                      child: Text(
                        "RAW PASTES",
                        style: TextStyle(
                          fontWeight: FontWeight.bold,
                          fontSize: 10,
                          color: Colors.blueGrey,
                        ),
                      ),
                    ),
                    Expanded(child: _buildVaultList()),
                  ],
                ),
              ),
            ],
          );
        },
      ),
    );
  }

  Widget _buildToolBar(BuildContext context) {
    return Wrap(
      spacing: 8,
      runSpacing: 8,
      alignment: WrapAlignment.spaceBetween,
      crossAxisAlignment: WrapCrossAlignment.center,
      children: [
        const Text(
          "Phoenix Board",
          style: TextStyle(fontSize: 22, fontWeight: FontWeight.w900),
        ),
        Row(
          mainAxisSize: MainAxisSize.min,
          children: [
            ElevatedButton.icon(
              onPressed: () => print("🚀 Triggering Gemini AI Analysis..."),
              icon: const Icon(Icons.auto_awesome, size: 14),
              label: const Text("Run AI", style: TextStyle(fontSize: 12)),
              style: ElevatedButton.styleFrom(
                backgroundColor: Colors.deepPurple,
                foregroundColor: Colors.white,
                padding: const EdgeInsets.symmetric(
                  horizontal: 12,
                  vertical: 8,
                ),
              ),
            ),
            IconButton(
              visualDensity: VisualDensity.compact,
              icon: const Icon(Icons.cloud_done_outlined, size: 20),
              onPressed: () {},
            ),
            IconButton(
              visualDensity: VisualDensity.compact,
              icon: const Icon(Icons.settings_outlined, size: 20),
              onPressed: () {},
            ),
            IconButton(
              visualDensity: VisualDensity.compact,
              icon: const Icon(Icons.close, size: 20),
              onPressed: onHide,
            ),
          ],
        ),
      ],
    );
  }

  Widget _buildInsightGrid() {
    final categories = [
      "War News",
      "Interesting Hotels",
      "Food & Dining",
      "Clothing",
    ];
    return GridView.builder(
      shrinkWrap: true,
      physics: const NeverScrollableScrollPhysics(),
      gridDelegate: const SliverGridDelegateWithMaxCrossAxisExtent(
        maxCrossAxisExtent: 350,
        crossAxisSpacing: 16,
        mainAxisSpacing: 16,
        childAspectRatio: 1.4,
      ),
      itemCount: categories.length,
      itemBuilder: (context, index) => Container(
        decoration: BoxDecoration(
          color: Colors.white,
          borderRadius: BorderRadius.circular(12),
          border: Border.all(color: Colors.grey[200]!),
          boxShadow: [
            BoxShadow(color: Colors.black.withOpacity(0.02), blurRadius: 8),
          ],
        ),
        padding: const EdgeInsets.all(16),
        child: Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            Text(
              categories[index],
              style: const TextStyle(fontWeight: FontWeight.bold, fontSize: 14),
            ),
            const Spacer(),
            const Text(
              "Analysis pending...",
              style: TextStyle(
                color: Colors.grey,
                fontSize: 11,
                fontStyle: FontStyle.italic,
              ),
            ),
          ],
        ),
      ),
    );
  }

  Widget _buildVaultList() {
    return ListView.separated(
      padding: const EdgeInsets.symmetric(horizontal: 4),
      itemCount: history.length,
      separatorBuilder: (context, index) =>
          const Divider(height: 1, color: Color(0xFFEEEEEE)),
      itemBuilder: (context, index) => ListTile(
        dense: true,
        // Numbered index for research tracking
        leading: Text(
          "${index + 1}",
          style: TextStyle(
            fontSize: 10,
            color: Colors.grey[400],
            fontWeight: FontWeight.bold,
          ),
        ),
        title: Text(
          history[index],
          maxLines: 1,
          overflow: TextOverflow.ellipsis,
          style: const TextStyle(fontSize: 12),
        ),
        onTap: () async {
          await Clipboard.setData(ClipboardData(text: history[index]));
        },
      ),
    );
  }
}
